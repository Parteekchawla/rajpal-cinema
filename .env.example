# Vista Cinema OCAPI Configuration
# ==================================
# To connect to the live Vista API, fill in your credentials below
# and rename this file to .env
#
# Without these values, the app runs in DEMO mode with mock data.

VITE_VISTA_BASE_URL=https://your-cinema.vista.co/ocapi/v1
VITE_VISTA_API_KEY=your-api-key-here
